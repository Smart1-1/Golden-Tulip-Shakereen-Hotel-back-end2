PORT=8787
DATA_DIR=./data
UPLOADS_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=30
API_BODY_LIMIT=15mb
# Exact hosts are matched while ignoring port, and localhost/127.0.0.1 are allowed on any port.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATA_STORAGE_DRIVER=file
UPLOADS_STORAGE_DRIVER=local

# PostgreSQL storage (required when DATA_STORAGE_DRIVER=postgres)
DATABASE_URL=
PG_SSL=false

# S3-compatible uploads (required when UPLOADS_STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=uploads
S3_FORCE_PATH_STYLE=false

# Optional: protect admin write/list endpoints.
ADMIN_API_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_SESSION_TTL_HOURS=168
